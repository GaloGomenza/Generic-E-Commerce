			"description": "Inicio y cierre de sesion",
			"item": [
				{
					"name": "RF 01 - Iniciar Sesion",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Token presente', () => pm.expect(pm.response.json().token).to.not.be.empty);",
									"pm.environment.set('admin_token', pm.response.json().token);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/users/login",
							"host": ["{{base_url}}"],
							"path": ["api", "users", "login"]
						}
					}
				},
				{
					"name": "RF 02 - Cerrar Sesion",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Mensaje de logout', () => pm.expect(pm.response.json().message).to.eql('Logged out successfully'));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "{{admin_token}}" },
							{ "key": "X-User-Email", "value": "{{admin_email}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/users/logout",
							"host": ["{{base_url}}"],
							"path": ["api", "users", "logout"]
						}
					}
